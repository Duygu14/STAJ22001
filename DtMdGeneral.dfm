  object oqAddMedCard: TOracleQuery
    SQL.Strings = (
      'DECLARE'
      '  lvSQL VARCHAR2(100);'
      'BEGIN'
      '  IF :NEW_ONE = 0 THEN'
      '    SELECT MAX(ID)'
      '      INTO :ID'
      '    FROM CONNECTIONS_OF_MEDCARD C'
      '    WHERE C.PT_ID = :PT_ID'
      '          AND C.OR_ID = :OR_ID;'
      '    IF :ID = 0 THEN'
      '      SELECT MC_CONNECTION_ID_SEQ.NEXTVAL'
      '        INTO :ID'
      '      FROM DUAL;'
      '      INSERT INTO CONNECTIONS_OF_MEDCARD'
      
        '      (ID, UPN , OR_ID, PT_ID, DR_ID, DEPT_ID, CUSER, CTIME, PRO' +
        'CESS_TIME, DNT_ID, IS_DIAG_CARD)'
      '      VALUES'
      
        '      (:ID, :UPN , :OR_ID, :PT_ID, :DR_ID, :DEPT_ID, :CUSER, :CT' +
        'IME, :PROCESS_TIME, :DNT_ID, :IS_DIAG_CARD);'
      ''
      
        '      lvSQL := '#39'INSERT INTO '#39'||:TABLE_NAME||'#39' (ID, COM_ID) VALUE' +
        'S ('#39'||:ID||'#39', '#39'||:SEQ_NAME||'#39'.NEXTVAL)'#39';'
      '      EXECUTE IMMEDIATE lvSQL;      '
      '    END IF;'
      '  ELSE'
      '    SELECT MC_CONNECTION_ID_SEQ.NEXTVAL'
      '      INTO :ID'
      '    FROM DUAL;'
      '    INSERT INTO CONNECTIONS_OF_MEDCARD'
      
        '    (ID, UPN , OR_ID, PT_ID, DR_ID, DEPT_ID, CUSER, CTIME, PROCE' +
        'SS_TIME, DNT_ID, IS_DIAG_CARD)'
      '    VALUES'
      
        '    (:ID, :UPN , :OR_ID, :PT_ID, :DR_ID, :DEPT_ID, :CUSER, :CTIM' +
        'E, :PROCESS_TIME, :DNT_ID, :IS_DIAG_CARD);'
      ''
      
        '    lvSQL := '#39'INSERT INTO '#39'||:TABLE_NAME||'#39' (ID, COM_ID) VALUES ' +
        '('#39'||:ID||'#39', '#39'||:SEQ_NAME||'#39'.NEXTVAL)'#39';'
      '    EXECUTE IMMEDIATE lvSQL;    '
      '  END IF;'
      'END;')
    Session = dmMain.OraSession
    Optimize = False
    Variables.Data = {
      040000000E000000060000003A00490044000300000000000000000000000800
      00003A00550050004E000300000000000000000000000C0000003A004F005200
      5F00490044000300000000000000000000000C0000003A00500054005F004900
      44000300000000000000000000000C0000003A00440052005F00490044000300
      00000000000000000000100000003A0044004500500054005F00490044000300
      000000000000000000000C0000003A0043005500530045005200050000000000
      0000000000000C0000003A004300540049004D0045000C000000000000000000
      00001A0000003A00500052004F0043004500530053005F00540049004D004500
      0C00000000000000000000000E0000003A0044004E0054005F00490044000300
      000000000000000000001A0000003A00490053005F0044004900410047005F00
      4300410052004400050000000000000000000000100000003A004E0045005700
      5F004F004E004500030000000000000000000000160000003A00540041004200
